# Required: OpenAI API key for conversation and plan generation
OPENAI_API_KEY=sk-...

# Optional: OpenAI model (defaults to gpt-4.1-mini)
OPENAI_MODEL=gpt-4.1-mini

# Optional: Coursera GraphQL endpoint (defaults to https://www.coursera.org/graphql-gateway)
COURSERA_GRAPHQL_ENDPOINT=https://www.coursera.org/graphql-gateway
